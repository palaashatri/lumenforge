{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build JForge",
			"type": "shell",
			"command": "mvn",
			"args": [
				"clean",
				"-DskipTests",
				"compile"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Run JForge",
			"type": "shell",
			"command": "mvn",
			"args": [
				"clean",
				"-DskipTests",
				"compile",
				"exec:java"
			],
			"isBackground": true,
			"group": {
				"kind": "test",
				"isDefault": false
			}
		},
		{
			"label": "Package JForge",
			"type": "shell",
			"command": "mvn",
			"args": [
				"clean",
				"-DskipTests",
				"package"
			],
			"isBackground": false
		},
		{
			"label": "Clean JForge",
			"type": "shell",
			"command": "mvn",
			"args": [
				"clean"
			],
			"isBackground": false
		}
	]
}